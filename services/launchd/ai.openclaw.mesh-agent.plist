<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>ai.openclaw.mesh-agent</string>
    <key>Comment</key>
    <string>OpenClaw Mesh Agent Worker — claims and executes tasks via Claude Code CLI. NOT auto-loaded — load manually with: launchctl load ~/Library/LaunchAgents/ai.openclaw.mesh-agent.plist</string>
    <key>ProgramArguments</key>
    <array>
      <string>${NODE_BIN}</string>
      <string>${OPENCLAW_REPO_DIR}/bin/mesh-agent.js</string>
    </array>
    <key>KeepAlive</key>
    <false/>
    <key>RunAtLoad</key>
    <false/>
    <key>StandardOutPath</key>
    <string>${OPENCLAW_WORKSPACE}/.tmp/mesh-agent.log</string>
    <key>StandardErrorPath</key>
    <string>${OPENCLAW_WORKSPACE}/.tmp/mesh-agent.err</string>
    <key>EnvironmentVariables</key>
    <dict>
      <key>HOME</key>
      <string>${HOME}</string>
      <key>PATH</key>
      <string>${OPENCLAW_WORKSPACE}/.npm-global/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
      <key>NODE_PATH</key>
      <string>${OPENCLAW_REPO_DIR}/node_modules:${OPENCLAW_REPO_DIR}/lib</string>
      <!-- Local-first: the mesh bus is loopback-only. -->
      <key>OPENCLAW_NATS</key>
      <string>nats://127.0.0.1:4222</string>
      <key>MESH_WORKSPACE</key>
      <string>${OPENCLAW_WORKSPACE}</string>
      <key>OPENCLAW_NODE_ID</key>
      <string>${OPENCLAW_NODE_ID}</string>
      <key>OPENCLAW_NODE_ROLE</key>
      <string>${OPENCLAW_NODE_ROLE}</string>
      <key>OPENCLAW_REPO_DIR</key>
      <string>${OPENCLAW_REPO_DIR}</string>
    </dict>
    <key>ThrottleInterval</key>
    <integer>30</integer>
  </dict>
</plist>
