<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>ai.openclaw.memory-daemon</string>
    <key>Comment</key>
    <string>OpenClaw Memory Daemon v2 — Node.js long-running process</string>
    <key>ProgramArguments</key>
    <array>
      <string>${NODE_BIN}</string>
      <string>${OPENCLAW_WORKSPACE}/bin/memory-daemon.mjs</string>
    </array>
    <key>KeepAlive</key>
    <true/>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${OPENCLAW_WORKSPACE}/.tmp/memory-daemon.log</string>
    <key>StandardErrorPath</key>
    <string>${OPENCLAW_WORKSPACE}/.tmp/memory-daemon.err</string>
    <key>EnvironmentVariables</key>
    <dict>
      <key>HOME</key>
      <string>${HOME}</string>
      <key>PATH</key>
      <string>${OPENCLAW_WORKSPACE}/.npm-global/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
      <key>TZ</key>
      <string>America/Montreal</string>
      <key>OPENCLAW_WORKSPACE</key>
      <string>${OPENCLAW_WORKSPACE}</string>
      <!-- R28 fix (repair 7.1): the Block-0 local-first wiring lived only in
           the hand-edited installed plist; a reinstall from this template
           silently reverted the daemon to the remote mesh IP and a
           hostname-derived stream name, killing the event spine. -->
      <key>OPENCLAW_NATS</key>
      <string>nats://127.0.0.1:4222</string>
      <key>OPENCLAW_NODE_ID</key>
      <string>${OPENCLAW_NODE_ID}</string>
    </dict>
    <key>ThrottleInterval</key>
    <integer>10</integer>
  </dict>
</plist>
