<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>ai.openclaw.nats</string>
    <key>Comment</key>
    <string>OpenClaw NATS — single-node bus (client 4222, monitor 8222, JetStream, token auth). The default bus every fresh node runs on; the R=3 cluster units are the operator-gated upgrade.</string>
    <key>ProgramArguments</key>
    <array>
      <string>${NATS_SERVER_BIN}</string>
      <string>--config</string>
      <string>${HOME}/.openclaw/config/nats.conf</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${HOME}/.openclaw/logs/nats.log</string>
    <key>StandardErrorPath</key>
    <string>${HOME}/.openclaw/logs/nats.err</string>
    <key>EnvironmentVariables</key>
    <dict>
      <key>HOME</key>
      <string>${HOME}</string>
    </dict>
    <key>ThrottleInterval</key>
    <integer>10</integer>
  </dict>
</plist>
