<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>ai.openclaw.health-watch</string>
    <key>Comment</key>
    <string>OpenClaw Health Watch — polls memory infrastructure components every 60s</string>
    <key>ProgramArguments</key>
    <array>
      <string>${NODE_BIN}</string>
      <string>${OPENCLAW_WORKSPACE}/bin/health-watch.mjs</string>
    </array>
    <key>KeepAlive</key>
    <true/>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${OPENCLAW_WORKSPACE}/.tmp/health-watch.log</string>
    <key>StandardErrorPath</key>
    <string>${OPENCLAW_WORKSPACE}/.tmp/health-watch.err</string>
    <key>EnvironmentVariables</key>
    <dict>
      <key>HOME</key>
      <string>${HOME}</string>
      <key>PATH</key>
      <string>${OPENCLAW_WORKSPACE}/.npm-global/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
      <key>TZ</key>
      <string>America/Montreal</string>
      <key>OPENCLAW_WORKSPACE</key>
      <string>${OPENCLAW_WORKSPACE}</string>
      <key>OPENCLAW_NATS</key>
      <string>nats://127.0.0.1:4222</string>
      <key>OPENCLAW_NODE_ID</key>
      <string>daedalus</string>
      <key>HEALTH_WATCH_INTERVAL_SEC</key>
      <string>60</string>
    </dict>
    <key>ThrottleInterval</key>
    <integer>30</integer>
  </dict>
</plist>
