# OpenClaw Environment Configuration — the node's functional parameters (docs/NODE_SPEC.md §3)
# install.sh copies this to ~/.openclaw/openclaw.env and appends generated values.

# ── Bus ──────────────────────────────────────────────────────────────────────
# NATS server URL — every subsystem talks through this (loopback by design)
OPENCLAW_NATS=nats://127.0.0.1:4222

# NATS auth token — REQUIRED server-side (D2 trust floor).
# install.sh generates one (openssl rand -hex 32) and appends it here + embeds
# it in the rendered NATS confs. Do not leave empty on a running node.
# OPENCLAW_NATS_TOKEN=

# Cluster-route password (multi-MACHINE councils only) — shared by every machine,
# authenticates the NATS cluster port (user openclaw-route). Generated by
# `install.sh --cluster-peers=…`; copy to each machine with the token above.
# OPENCLAW_NATS_CLUSTER_PASS=

# KV/stream replica target — how many machines keep a copy of the mesh data
# (task list, sessions, grappe registry). 1 = single machine (no failsafe);
# 3 = a real 3-machine council survives losing any one machine. Set by
# `install.sh --cluster-peers=…` from the council size; leave unset on a solo box.
# OPENCLAW_KV_REPLICAS=1

# ── Node identity ────────────────────────────────────────────────────────────
# Role — 'lead' or 'worker' (default: macOS=lead, Linux=worker)
# OPENCLAW_NODE_ROLE=worker
# Node ID — auto-detected from hostname if not set
# OPENCLAW_NODE_ID=my-node-name

# ── LLM backend ─────────────────────────────────────────────────────────────
# Grappe-worker provider = the node's OpenClaw frontend (advanced LLM). D11: a
# grappe/cluster worker MUST be an advanced LLM (claude/openai/gemini/deepseek/
# kimi/minimax/aider), NEVER a local model — mesh-agent refuses ollama here.
MESH_LLM_PROVIDER=claude
# Local model tag for the EXTRACTION/embedding/probe organ ONLY (never a grappe
# worker's mind). install.sh upgrades this to your RAM tier via check-llm-baseline
# (16GB→qwen3:8b · 32GB→qwen3:14b · 48GB→qwen3:32b)
LLM_MODEL=qwen3:8b
# Ollama endpoint (extraction + probes)
LLM_BASE_URL=http://localhost:11434
# Memory extraction mode — true = LLM extraction (falls back to regex if the
# model is unreachable; node-watch reports the degradation)
USE_LLM_EXTRACTION=true
# format:"json" is auto-disabled for thinking-family models (qwen3/deepseek-r1/
# magistral/gpt-oss) — the JSON grammar stalls llama.cpp's decoder on them
# (2026-07-18: 45h zero-fact extraction stall). Set =1 to force free-form for
# EVERY model; the tolerant extraction parser handles both.
#LLM_FORCE_FREE_FORM=1

# ── Misc ─────────────────────────────────────────────────────────────────────
OPENCLAW_TIMEZONE=America/Montreal

# ── Optional feature keys (core node needs NONE of these) ───────────────────
# ANTHROPIC_API_KEY=            # cloud extraction/agents via API
# OPENAI_API_KEY=               # openai-provider agents
# GOOGLE_API_KEY=               # Mission Control TTS voice
# DISCORD_BOT_TOKEN=            # mesh-tool-discord (enable its unit after setting)
# OBSIDIAN_API_KEY=             # Obsidian Local REST sync
# KNOWLEDGE_MODEL=Xenova/bge-m3 # embedder override (default shown)
# LLM_TIMEOUT=600000            # extraction generation budget (ms)
