# OpenClaw Environment Configuration
# Copy to ~/.openclaw/openclaw.env and edit values

# NATS server URL — required for mesh communication
# Set to the IP of the node running the NATS server
OPENCLAW_NATS=nats://127.0.0.1:4222

# NATS auth token — optional, enables server-side authentication
# Set the same token on the NATS server (--auth flag) and all clients
# Leave empty to disable auth (Tailscale VPN is the security perimeter)
# OPENCLAW_NATS_TOKEN=

# Node role — 'lead' or 'worker' (auto-detected if not set: macOS=lead, Linux=worker)
# OPENCLAW_NODE_ROLE=worker

# Node ID — auto-detected from hostname if not set
# OPENCLAW_NODE_ID=my-node-name
