#!/usr/bin/env bash
# skill-quality-check — Compare current skill audit against last cached result.
# Outputs regressions if any, otherwise silent.
# Used by heartbeat for periodic quality monitoring.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE="${SCRIPT_DIR}/.."
CACHE_DIR="${WORKSPACE}/.tmp"
CACHE_FILE="${CACHE_DIR}/last-skill-audit.json"
EVENTS_FILE="${WORKSPACE}/skills/capability-evolver/assets/gep/events.jsonl"

mkdir -p "$CACHE_DIR"

# Run current audit
if ! CURRENT=$(python3 "${SCRIPT_DIR}/skill-audit" --json 2>/dev/null); then
  echo "ERROR: skill-audit failed"
  exit 1
fi

CURRENT_AVG=$(echo "$CURRENT" | python3 -c "import sys,json; print(json.load(sys.stdin)['average_score'])")
CURRENT_DIST=$(echo "$CURRENT" | python3 -c "
import sys,json
d=json.load(sys.stdin)['grade_distribution']
parts=[f\"{g}:{d[g]}\" for g in ['A','B','C','D','F'] if d.get(g,0)>0]
print(' '.join(parts))
")

# Compare against cache
if [ -f "$CACHE_FILE" ]; then
  PREV_AVG=$(python3 -c "import json,sys; print(json.load(sys.stdin)['average_score'])" < "$CACHE_FILE" 2>/dev/null || echo "0")

  # Find regressions (skills that dropped grade) — data passed via stdin, not string interpolation
  REGRESSIONS=$(python3 -c "
import json, sys

data = json.load(sys.stdin)
prev_data = data['prev']
curr_data = data['curr']

prev = {s['name']: s['grade'] for s in prev_data.get('skills', [])}
curr = {s['name']: s['grade'] for s in curr_data.get('skills', [])}

grade_rank = {'A': 0, 'B': 1, 'C': 2, 'D': 3, 'F': 4}
regs = []
for name, grade in curr.items():
    old = prev.get(name)
    if old and grade_rank.get(grade, 5) > grade_rank.get(old, 5):
        regs.append(f'{name}: {old}->{grade}')

if regs:
    print('REGRESSIONS: ' + ', '.join(regs))
else:
    print('OK')
" < <(python3 -c "
import json, sys
prev = json.load(open(sys.argv[1]))
curr = json.loads(sys.stdin.read())
json.dump({'prev': prev, 'curr': curr}, sys.stdout)
" "$CACHE_FILE" <<< "$CURRENT") 2>/dev/null || echo "OK")

  if [[ "$REGRESSIONS" == OK ]]; then
    # Find improvements
    IMPROVEMENTS=$(python3 -c "
import json, sys

data = json.load(sys.stdin)
prev = {s['name']: s['grade'] for s in data['prev'].get('skills', [])}
curr = {s['name']: s['grade'] for s in data['curr'].get('skills', [])}

grade_rank = {'A': 0, 'B': 1, 'C': 2, 'D': 3, 'F': 4}
imps = []
for name, grade in curr.items():
    old = prev.get(name)
    if old and grade_rank.get(grade, 5) < grade_rank.get(old, 5):
        imps.append(f'{name}: {old}->{grade}')
print(','.join(imps) if imps else 'none')
" < <(python3 -c "
import json, sys
prev = json.load(open(sys.argv[1]))
curr = json.loads(sys.stdin.read())
json.dump({'prev': prev, 'curr': curr}, sys.stdout)
" "$CACHE_FILE" <<< "$CURRENT") 2>/dev/null || echo "none")

    # Silent if no changes
    if [[ "$IMPROVEMENTS" == "none" ]]; then
      # Update cache and exit silently
      echo "$CURRENT" > "$CACHE_FILE"
      exit 0
    fi
  fi

  # Report
  echo "Skill Quality: ${CURRENT_AVG}/100 (${CURRENT_DIST})"
  echo "$REGRESSIONS"
  if [[ "${IMPROVEMENTS:-none}" != "none" ]]; then
    echo "IMPROVEMENTS: $IMPROVEMENTS"
  fi

  # Append GEP event — data passed safely via stdin
  if [ -d "$(dirname "$EVENTS_FILE")" ]; then
    TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    python3 -c "
import json, sys

data = json.load(sys.stdin)
event = {
    'type': 'EvolutionEvent',
    'timestamp': data['timestamp'],
    'category': 'quality_audit',
    'summary': data['summary'],
    'changes': {
        'regressions': data['regressions'].split(', ') if data['regressions'] != 'OK' else [],
        'improvements': data['improvements'].split(',') if data['improvements'] != 'none' else []
    }
}
print(json.dumps(event))
" < <(python3 -c "
import json, sys
json.dump({
    'timestamp': sys.argv[1],
    'summary': sys.argv[2],
    'regressions': sys.argv[3],
    'improvements': sys.argv[4]
}, sys.stdout)
" "$TIMESTAMP" "${CURRENT_AVG}/100 (${CURRENT_DIST})" "${REGRESSIONS}" "${IMPROVEMENTS:-none}") >> "$EVENTS_FILE" 2>/dev/null || true
  fi
else
  echo "First run — baseline captured: ${CURRENT_AVG}/100 (${CURRENT_DIST})"
fi

# Update cache
echo "$CURRENT" > "$CACHE_FILE"
